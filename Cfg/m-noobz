clear
echo -e "==================================================="
echo -e "                • MEMBER  NOOBZ •                  "
echo -e "==================================================="
noobzvpns --info-all-user | awk '/^\s*\+.*-> active/ {gsub(/(issued\(yyyymmdd\)|hash_key): [0-9a-f]+/, ""); print; getline; print; getline; getline; getline; print; print "═══════════════════"}'
echo ""
read -n 1 -s -r -p "Press any key to back on menu"
