function remove(){
clear
echo -e "==================================================="
echo -e "               • REMOVE  NOOBZ •                   "
echo -e "==================================================="

read -p "Apakah Anda ingin menghapus semua user? (Y/N): " choice

if [ "$choice" == "Y" ] || [ "$choice" == "y" ]; then
    # Eksekusi perintah di sini
    echo "MENGHAPUS SEMUA USER!"
noobzvpns --remove-all-user
elif [ "$choice" == "N" ] || [ "$choice" == "n" ]; then
    echo "Membatalkan penghapusan."
menu-noobzvpns
else
    echo "Pilihan tidak valid."
fi

clear
echo -e "==================================================="
echo -e "               • REMOVE  NOOBZ •                   "
echo -e "==================================================="
echo "USERNAME: $user"
echo "unlocked success!!"
echo ""
read -n 1 -s -r -p "Press any key to back on menu"
menu
}




clear
echo -e "==================================================="
echo -e "                • NOOBZ PANEL MENU •               "
echo -e "==================================================="
echo -e "  [01] • ADD AKUN        [04] • DELETE USER        "
echo -e "  [02] • SHOW AKUN       [05] • LOCKED USER        "
echo -e "  [03] • RENEW AKUN      [06] • UNLOCKED USER      "
echo -e "  [00] • GO BACK         [07] • REMOVE ALL USER    "
echo -e "==================================================="
echo -e ""
echo -ne " Select menu : "; read opt
case $opt in
01 | 1) clear ; create ;;
02 | 2) clear ; show ;;
03 | 3) clear ; renew ;;
04 | 4) clear ; delete ;;
05 | 5) clear ; lock ;;
06 | 6) clear ; unlock ;;
07 | 7) clear ; remove ;;
100) clear ; $up2u ;;
00 | 0) clear ; menu ;;
*) clear ; menu ;;
esac